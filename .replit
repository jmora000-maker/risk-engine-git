run = "streamlit run app.py --server.port 8080 --server.address 0.0.0.0"
modules = ["python-3.11", "nodejs-20"]

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 6000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8501
externalPort = 80

[[ports]]
localPort = 8502
externalPort = 3000

[[ports]]
localPort = 8503
externalPort = 3002

[[ports]]
localPort = 8504
externalPort = 3003

[[ports]]
localPort = 8505
externalPort = 3001

[[ports]]
localPort = 8506
externalPort = 4200

[[ports]]
localPort = 8507
externalPort = 5000

[[ports]]
localPort = 8508
externalPort = 5173

[nix]
packages = ["csound"]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd scripts/src && streamlit run app.py --server.port 8000"
waitForPort = 8000

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "cd scripts/src && streamlit run app.py --server.port 8080 --server.address 0.0.0.0"]
